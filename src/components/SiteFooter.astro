---
import { siteConfig } from '../lib/site'
import KoiMark from './KoiMark.astro'
const year = new Date().getFullYear()
---

<footer class="bg-ink-deep text-paper">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-6 px-6 py-12 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex items-center gap-2.5">
      <KoiMark class="text-koi-300 h-6 w-6" />
      <p class="text-paper-warm text-sm">© {year} {siteConfig.author}</p>
    </div>
    <ul class="flex items-center gap-5 text-sm">
      <li>
        <a class="hover:text-koi-300 transition-colors" href={siteConfig.social.github}>GitHub</a>
      </li>
      <li>
        <a class="hover:text-koi-300 transition-colors" href={siteConfig.social.linkedin}
          >LinkedIn</a
        >
      </li>
      <li><a class="hover:text-koi-300 transition-colors" href={siteConfig.social.x}>X</a></li>
      <li>
        <a class="hover:text-koi-300 transition-colors" href={`mailto:${siteConfig.email}`}>Email</a
        >
      </li>
      <li><a class="hover:text-koi-300 transition-colors" href="/rss.xml">RSS</a></li>
      <li><a class="hover:text-koi-300 transition-colors" href="/privacy">Privacy</a></li>
    </ul>
  </div>
</footer>
