---
import { formatDate } from '../lib/formatDate'

interface Props {
  author: { name: string; isAI: boolean }
  date?: Date
}
const { author, date } = Astro.props
const tone = author.isAI ? 'bg-spark-100 text-spark-700' : 'bg-koi-100 text-koi-700'
---

<span class="text-ink-soft inline-flex items-center gap-2 text-sm">
  <span class={`rounded-full px-2.5 py-0.5 font-medium ${tone}`}>{author.name}</span>
  {date && <time datetime={date.toISOString().slice(0, 10)}>{formatDate(date)}</time>}
</span>
