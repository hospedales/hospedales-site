---
import Base from './Base.astro'
import BylineChip from '../components/BylineChip.astro'
import AttributionBanner from '../components/AttributionBanner.astro'
import { articleJsonLd } from '../lib/jsonld'

interface Props {
  title: string
  description: string
  pubDate: Date
  updatedDate?: Date
  author: { name: string; isAI: boolean; model?: string }
  tags: string[]
  ogImagePath?: string
}
const { title, description, pubDate, updatedDate, author, tags, ogImagePath } = Astro.props
const jsonLd = articleJsonLd({
  title,
  description,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  pubDate,
  updatedDate,
  author,
})
---

<Base title={`${title} — Michael Hospedales`} {description} {ogImagePath}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  <article class="mx-auto max-w-3xl px-6 py-16">
    <header class="mb-10">
      <BylineChip {author} date={pubDate} />
      <h1 class="font-display text-ink-deep mt-4 text-4xl leading-tight font-semibold sm:text-5xl">
        {title}
      </h1>
      {
        tags.length > 0 && (
          <ul class="text-ink-soft mt-4 flex flex-wrap gap-2 text-xs font-medium tracking-wide uppercase">
            {tags.map((tag) => (
              <li class="border-paper-warm rounded border px-2 py-0.5">{tag}</li>
            ))}
          </ul>
        )
      }
      <div class="mt-6">
        <AttributionBanner {author} />
      </div>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</Base>
