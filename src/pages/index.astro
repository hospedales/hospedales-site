---
import { getCollection, getEntry } from 'astro:content'
import Base from '../layouts/Base.astro'
import KoiMark from '../components/KoiMark.astro'
import PostCard from '../components/PostCard.astro'
import ProjectCard from '../components/ProjectCard.astro'
import { siteConfig } from '../lib/site'
import { personJsonLd } from '../lib/jsonld'
import { sortPosts } from '../lib/posts'
import { formatDate } from '../lib/formatDate'
import { now } from '../data/now'

const featured = (await getCollection('projects', ({ data }) => data.featured))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3)
const latest = sortPosts(await getCollection('blog')).slice(0, 3)
const authors = new Map(
  await Promise.all(
    ['michael', 'spark'].map(async (id) => [id, (await getEntry('authors', id))!.data] as const),
  ),
)
---

<Base title={siteConfig.title} description={siteConfig.description}>
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd())} is:inline />

  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-20 sm:pt-24">
    <div class="flex items-start justify-between gap-8">
      <div class="max-w-3xl">
        <p class="text-koi-600 text-sm font-semibold tracking-widest uppercase">
          Michael Hospedales · Software Engineer
        </p>
        <h1
          class="font-display text-ink-deep mt-4 text-5xl leading-[1.05] font-semibold tracking-tight sm:text-7xl"
        >
          Building for the web by day. Teaching my homelab to build by night.
        </h1>
        <p class="text-ink-soft mt-6 max-w-2xl text-lg leading-relaxed">
          Front-end engineer with full-stack range. I ship web products, run AI infrastructure at
          home on an NVIDIA DGX Spark, and publish the results — some posts here are written by the
          machine itself, reviewed by me.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/projects"
            class="bg-ink text-paper hover:bg-koi-600 rounded-md px-6 py-3 font-medium transition-colors"
          >
            See what I'm building
          </a>
          <a
            href="/about"
            class="border-ink text-ink hover:border-koi-600 hover:text-koi-600 rounded-md border px-6 py-3 font-medium transition-colors"
          >
            About me
          </a>
        </div>
      </div>
      <KoiMark class="text-koi-300 mt-6 hidden h-40 w-40 shrink-0 sm:block" />
    </div>
  </section>

  <!-- Now -->
  <section class="border-paper-warm bg-paper-warm/50 border-y">
    <div class="mx-auto max-w-5xl px-6 py-10">
      <div class="flex items-baseline justify-between">
        <h2 class="font-display text-ink-deep text-2xl font-semibold">Now</h2>
        <p class="text-ink-soft text-xs">Updated {formatDate(new Date(now.updated))}</p>
      </div>
      <ul class="mt-4 grid gap-3 sm:grid-cols-3">
        {
          now.items.map((item) => (
            <li class="border-koi-500 text-ink border-l-2 pl-4 text-sm leading-relaxed">{item}</li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="flex items-baseline justify-between">
      <h2 class="font-display text-ink-deep text-3xl font-semibold">Building</h2>
      <a href="/projects" class="text-koi-600 text-sm font-medium hover:underline">All projects →</a
      >
    </div>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((p) => (
          <ProjectCard
            href={`/projects/${p.id}`}
            title={p.data.title}
            summary={p.data.summary}
            status={p.data.status}
            stack={p.data.stack}
          />
        ))
      }
    </div>
  </section>

  <!-- Latest writing -->
  <section class="mx-auto max-w-5xl px-6 pb-16">
    <div class="flex items-baseline justify-between">
      <h2 class="font-display text-ink-deep text-3xl font-semibold">Writing</h2>
      <a href="/blog" class="text-koi-600 text-sm font-medium hover:underline">All posts →</a>
    </div>
    <div class="mt-4 max-w-3xl">
      {
        latest.map((post) => (
          <PostCard
            href={`/blog/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.pubDate}
            author={authors.get(post.data.author)!}
          />
        ))
      }
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="bg-ink-deep">
    <div
      class="mx-auto flex max-w-5xl flex-col items-start gap-6 px-6 py-16 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <h2 class="font-display text-paper text-3xl font-semibold">Building something?</h2>
        <p class="text-paper-warm mt-2 max-w-xl">
          I'm open to conversations about founding-engineer roles, collaborations, and interesting
          problems.
        </p>
      </div>
      <a
        href="/contact"
        class="bg-koi-500 text-paper hover:bg-koi-600 rounded-md px-6 py-3 font-medium transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>
</Base>
