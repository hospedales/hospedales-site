---
import Base from '../layouts/Base.astro'
import KoiMark from '../components/KoiMark.astro'
---

<Base title="Not found — Michael Hospedales" description="This page swam away.">
  <section class="mx-auto flex max-w-2xl flex-col items-start gap-6 px-6 py-24">
    <KoiMark class="text-koi-300 h-16 w-16" />
    <h1 class="font-display text-ink-deep text-5xl font-semibold">This page swam away.</h1>
    <p class="text-ink-soft text-lg">The page you're after doesn't exist (anymore).</p>
    <a
      href="/"
      class="bg-ink text-paper hover:bg-koi-600 rounded-md px-5 py-2.5 font-medium transition-colors"
    >
      Back to shore
    </a>
  </section>
</Base>
